################################################################################
# Nostrum Cross-Faction Module
#
# Philosophy:
# Keep faction identity in the open world, but enable cross-faction systems
# where they help queues, grouping, communication, and server health.
#
# Features that require core config changes are validated at startup.
# Features that require a core patch or external module (RDF mixing, BG mixing)
# are logged as warnings when enabled — they do not have fake stubs.
################################################################################

[worldserver]

# Master switch.
# Default: 1
NostrumCrossFaction.Enable = 1

################################################################################
# Communication
################################################################################

# Allow Alliance and Horde players to communicate through normal chat.
# Requires AllowTwoSide.Interaction.Chat = 1 in worldserver.conf.
# Default: 1
NostrumCrossFaction.Chat.Enable = 1

# Allow Alliance and Horde players to share custom chat channels such as /world.
# Requires AllowTwoSide.Interaction.Channel = 1 in worldserver.conf.
# Default: 1
NostrumCrossFaction.Channels.Enable = 1

# Allow Alliance and Horde players to see each other in /who.
# Requires AllowTwoSide.WhoList = 1 in worldserver.conf.
# Default: 1
NostrumCrossFaction.WhoList.Enable = 1

################################################################################
# World Channel Integration
################################################################################

# Auto-join players to a global world channel on login.
# Default: 1
NostrumCrossFaction.WorldChannel.Enable = 1

# Name of the global world channel.
# Default: world
NostrumCrossFaction.WorldChannel.Name = world

# Send a message when the player joins the world channel on login.
# Default: 1
NostrumCrossFaction.WorldChannel.LoginMessage.Enable = 1

# Message shown to the player on login.
# Default: You have joined /world. Use it for global chat, questions, groups, and trading.
NostrumCrossFaction.WorldChannel.LoginMessage = You have joined /world. Use it for global chat, questions, groups, and trading.

# Minimum level required to speak in the world channel.
# Players below this level may still join and read if auto-join is enabled.
# Set to 0 to disable the level restriction.
# Default: 5
NostrumCrossFaction.WorldChannel.MinSpeakLevel = 5

# Cooldown in seconds between messages in the world channel.
# Set to 0 to disable the cooldown.
# Default: 3
NostrumCrossFaction.WorldChannel.MessageCooldownSeconds = 3

################################################################################
# Economy
################################################################################

# Allow cross-faction auction house interaction.
# Requires AllowTwoSide.Interaction.Auction = 1 in worldserver.conf.
# Default: 1
NostrumCrossFaction.AuctionHouse.Enable = 1

# Allow cross-faction mail.
# Requires AllowTwoSide.Interaction.Mail = 1 in worldserver.conf.
# Recommended default for launch: 0
# Default: 0
NostrumCrossFaction.Mail.Enable = 0

# Allow cross-faction direct trading.
# When disabled, the module blocks trades between players of different factions.
# Recommended default for launch: 0
# Default: 0
NostrumCrossFaction.Trading.Enable = 0

################################################################################
# Groups and Parties
################################################################################

# Allow normal manual cross-faction parties in the open world.
# When disabled, OnPlayerCanGroupInvite blocks cross-faction invites.
# Recommended default for launch: 0
# Default: 0
NostrumCrossFaction.ManualGroups.Enable = 0

# Allow cross-faction groups formed through the dungeon/RDF system.
# Default: 1
NostrumCrossFaction.DungeonGroups.Enable = 1

# Attempt to restrict cross-faction dungeon groups to instance content.
# Full enforcement depends on AllowTwoSide.Interaction.Group and hook availability.
# Default: 1
NostrumCrossFaction.DungeonGroups.RestrictToInstances = 1

# Disband or normalize cross-faction dungeon groups when players leave the dungeon.
# Default: 1
NostrumCrossFaction.DungeonGroups.CleanupOutsideInstance = 1

################################################################################
# Dungeon Finder / RDF
#
# NOTE: RDF cross-faction queue matching cannot be implemented from a module
# without a core patch. When enabled, the module logs a warning explaining
# what is required. See LFGMgr::FindNewGroups / LFGMgr::MakeNewGroup.
################################################################################

# Enable cross-faction Dungeon Finder / RDF matching.
# Default: 1
NostrumCrossFaction.RDF.Enable = 1

# Allow Alliance and Horde players to be matched into the same RDF group.
# Default: 1
NostrumCrossFaction.RDF.MixedFactionGroups = 1

# Keep RDF role checks and teleport behavior unchanged unless required.
# Default: 1
NostrumCrossFaction.RDF.PreserveBlizzlikeFlow = 1

################################################################################
# Battlegrounds
#
# NOTE: Cross-faction battleground mixing requires mod-cfbg or a compatible
# implementation. When enabled, the module logs a warning and defers to mod-cfbg.
################################################################################

# Enable cross-faction battleground support.
# Default: 1
NostrumCrossFaction.Battlegrounds.Enable = 1

# Allow faction mixing in battleground teams when needed for queue health.
# Default: 1
NostrumCrossFaction.Battlegrounds.MixedTeams = 1

# Prefer team balance over faction purity in BG queue assignment.
# Default: 1
NostrumCrossFaction.Battlegrounds.PrioritizeQueueHealth = 1

################################################################################
# Guilds
################################################################################

# Allow normal cross-faction guilds.
# Requires AllowTwoSide.Interaction.Guild = 1 in worldserver.conf.
# Recommended default for launch: 0
# Default: 0
NostrumCrossFaction.Guilds.Enable = 0

# Allow specific system-managed cross-faction guilds (e.g. Hardcore guilds).
# This module does not implement Hardcore guild logic. It only provides policy
# permission for guilds managed by other modules such as mod-nostrum-hardcore.
# Default: 1
NostrumCrossFaction.SystemGuilds.Enable = 1

# Comma-separated list of system-managed guild names that are exempt from the
# normal cross-faction guild restriction.
# Default: Deathwalkers
NostrumCrossFaction.SystemGuilds.AllowedNames = Deathwalkers

################################################################################
# Open World Restrictions
################################################################################

# Preserve faction identity in the open world.
# Default: 1
NostrumCrossFaction.OpenWorld.PreserveFactionIdentity = 1

# Prevent cross-faction manual grouping outside instances where possible.
# Default: 1
NostrumCrossFaction.OpenWorld.BlockManualCrossFactionGroups = 1

# Prevent cross-faction direct trading where possible.
# Default: 1
NostrumCrossFaction.OpenWorld.BlockCrossFactionTrading = 1

################################################################################
# Logging / Debug
################################################################################

# Log module configuration and validation on startup.
# Default: 1
NostrumCrossFaction.LogConfig = 1

# Verbose per-action debug logging.
# Leave disabled in production.
# Default: 0
NostrumCrossFaction.Debug = 0
