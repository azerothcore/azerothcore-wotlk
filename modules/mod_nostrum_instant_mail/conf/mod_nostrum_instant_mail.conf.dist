################################################################################
# NostrumWoW Instant Mail
#
# Removes the mail delivery delay for all player-to-player mail (items, gold,
# text).
#
# Unaffected mail types keep their default AzerothCore behaviour:
#   - Auction House mail, GM mail, system mail, and COD mail.
################################################################################

[worldserver]

# Enable instant delivery for all player-to-player mail.
# Set to 0 to restore the default AzerothCore delivery delay.
# Default: 1
NostrumInstantOwnMail.Enable = 1

# Log each mail delivery at INFO level. Useful for debugging.
# Leave disabled in production.
# Default: 0
NostrumInstantOwnMail.Debug = 0
