################################################################################
# Level Rewards Module Configuration
################################################################################

[worldserver]

# Enable or disable this module.
# Default: 1 (enabled)
LevelRewards.Enable = 1

# Subject line of the reward mail.
# Supports {level} placeholder.
# Default: "Level {level} Milestone Reward!"
LevelRewards.Subject = "Level {level} Milestone Reward!"

# Body of the reward mail.
# Supports {level} placeholder.
# Default: (community message)
LevelRewards.Message = "Congratulations on reaching level {level}!$B$BYour journey through NostrumWoW continues, and the community is glad to have you with us.$B$BPlease accept this small milestone reward to help you on your way. Safe travels, adventurer.$B$B— The NostrumWoW Team"
# Gold reward per level milestone (in whole gold).
# Set to 0 to disable a specific level.
LevelRewards.Gold.10 = 0
LevelRewards.Gold.20 = 1
LevelRewards.Gold.30 = 5
LevelRewards.Gold.40 = 15
LevelRewards.Gold.50 = 35
LevelRewards.Gold.60 = 100
LevelRewards.Gold.70 = 250
LevelRewards.Gold.80 = 500
