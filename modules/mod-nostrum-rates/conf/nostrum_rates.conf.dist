################################################################################
# NostrumWoW Rates Module
#
# All rates stack on top of worldserver.conf rates.
# Set Rate.XP.Kill, Rate.XP.Quest, Rate.Drop.Item.*, etc. to 1.0 in
# worldserver.conf to give this module full control.
#
# Valid range for all multipliers: 0.0 - 100.0
# Invalid values are rejected and the default is used (a warning is logged).
################################################################################

[worldserver]

# Master switch. Set to 0 to disable all rate modifications.
# Default: 1
NostrumRates.Enable = 1

################################################################################
# Active Era / Phase
#
# Controlled via Nostrum.Progression.Era and Nostrum.Progression.Phase in
# mod_nostrum_progression.conf. Those values drive both the level cap and
# the XP rate brackets + Death Knight lock. Do not duplicate them here.
#
# See mod_nostrum_progression.conf for the full era/phase table.
################################################################################

################################################################################
# XP Rates
#
# XP scaling is phase-driven. No manual bracket configuration is needed.
#
#   Phase 0 (Beta)           : BetaRate applied to all XP sources (default 3x)
#   Active phase bracket     : CurrentPhaseRate (default 1x, blizzlike)
#   Previous phase brackets  : CatchUpRate (default 2x, catch-up for new/returning players)
#
# Boundary levels (19, 29, etc.) resolve to the higher-numbered bracket,
# so a level-19 player in Phase 2 receives the current-phase rate.
#
# NOTE: BG XP bypasses phase scaling (handled by mod-nostrum-bg-xp).
#       Rested XP cannot be modified via module hooks (worldserver.conf only).
################################################################################

# Phase 0 flat rate applied to all XP sources.
# Default: 3.0
NostrumRates.XP.BetaRate = 3.0

# XP rate for players within the active phase's level bracket (blizzlike).
# Default: 1.0
NostrumRates.XP.CurrentPhaseRate = 1.0

# XP rate for players in previous phase brackets (catch-up).
# Default: 2.0
NostrumRates.XP.CatchUpRate = 2.0

# Battleground completion XP — not phase-scaled.
# Default: 1.0
NostrumRates.XP.Battleground = 1.0

################################################################################
# Death Knight Creation Lock
#
# When enabled, Death Knight character creation is blocked before Northrend Era.
# Death Knights start at level 55 and belong to WotLK content (Northrend Era).
#
# Default: 1
################################################################################

NostrumRates.BlockDKBeforeNorthrendEra = 1

################################################################################
# Reputation Rates
################################################################################

NostrumRates.Reputation.Kill  = 1.0
NostrumRates.Reputation.Quest = 1.0

################################################################################
# Profession Skill Gain
#
# Gathering: mining, herbalism, skinning.
# Crafting:  all tradeskill crafting.
#
# NOTE: Fishing skill gain cannot be modified via the available hooks.
################################################################################

NostrumRates.Profession.GatheringSkillGain = 1.0
NostrumRates.Profession.CraftingSkillGain  = 1.0

################################################################################
# Loot Drop Chance Multipliers
#
# Applied to item drop chance rolls. Does not affect guaranteed (100%) drops.
#
# IMPORTANT: Mining and Herbalism share gameobject_loot_template — the Mining
# rate applies to both. Set Herbalism to the same value to avoid a warning.
################################################################################

NostrumRates.Loot.Creature      = 1.0
NostrumRates.Loot.Skinning      = 1.0
NostrumRates.Loot.Fishing       = 1.0
NostrumRates.Loot.Mining        = 1.0
NostrumRates.Loot.Herbalism     = 1.0  # must equal Mining (see note above)
NostrumRates.Loot.Disenchanting = 1.0
NostrumRates.Loot.Prospecting   = 1.0
NostrumRates.Loot.Milling       = 1.0

################################################################################
# Money Rates
################################################################################

NostrumRates.Money.Creature = 1.0

################################################################################
# PvP Rates
################################################################################

NostrumRates.PvP.Honor       = 1.0
NostrumRates.PvP.ArenaPoints = 1.0
