#!/usr/bin/env bash
#
# mod-branding pre-commit hook (org workflow: gitleaks + linters + guards).
#
# Mirrors the CI gates so problems surface before they ever reach the remote:
#   1. gitleaks   -- secret scan of the staged change.
#   2. core-purity -- src/core/ must not depend on AzerothCore.
#   3. codestyle-cpp.py -- C++ style (run from the module root so it scans modules/mod-branding/src).
#   4. codestyle-sql.py -- SQL style (only if the repo's data/sql tree is reachable).
#   5. standalone core tests -- fast (<10s) build + run of the pure-core GoogleTests.
#
# INSTALL (from the AzerothCore repo root):
#   ln -sf ../../modules/mod-branding/tools/pre-commit .git/hooks/pre-commit
#   # or, if you keep hooks elsewhere:
#   git config core.hooksPath modules/mod-branding/tools   # uses this file directly
#
# Skip once (emergencies only):  git commit --no-verify
# Requires: bash, python3, cmake, a C++20 compiler. gitleaks is optional but recommended
# (install: https://github.com/gitleaks/gitleaks). If gitleaks is absent the hook WARNS and
# continues so a missing tool never silently blocks every commit.

set -euo pipefail

# --- locate the module and the repo root -----------------------------------------------------
HOOK_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
MODULE_ROOT="$(cd -- "${HOOK_PATH}/.." >/dev/null 2>&1 && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel)"
CODESTYLE_DIR="${REPO_ROOT}/apps/codestyle"

fail=0
note()  { printf '\033[1;34m[pre-commit]\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m[pre-commit][warn]\033[0m %s\n' "$*"; }
bad()   { printf '\033[1;31m[pre-commit][FAIL]\033[0m %s\n' "$*"; fail=1; }

# Only run the module gates when this commit actually touches the module.
if git diff --cached --name-only | grep -q '^modules/mod-branding/'; then
    note "mod-branding changes detected -- running module gates."
else
    note "no mod-branding changes staged -- running secret scan only."
fi

# --- 1. gitleaks (secret scan) ----------------------------------------------------------------
if command -v gitleaks >/dev/null 2>&1; then
    note "gitleaks: scanning staged changes..."
    if ! gitleaks protect --staged --redact --no-banner; then
        bad "gitleaks found potential secrets in the staged change."
    fi
else
    warn "gitleaks not installed -- skipping secret scan (install: https://github.com/gitleaks/gitleaks)."
fi

# The remaining gates only matter when the module changed.
if git diff --cached --name-only | grep -q '^modules/mod-branding/'; then

    # --- 2. core-purity -----------------------------------------------------------------------
    note "core-purity: checking src/core/ for AzerothCore dependencies..."
    if ! bash "${MODULE_ROOT}/tools/core-purity.sh"; then
        bad "core-purity guard failed."
    fi

    # --- 3. codestyle-cpp ---------------------------------------------------------------------
    if [[ -f "${CODESTYLE_DIR}/codestyle-cpp.py" ]]; then
        note "codestyle-cpp: linting modules/mod-branding/src..."
        if ! ( cd "${MODULE_ROOT}" && python3 "${CODESTYLE_DIR}/codestyle-cpp.py" ); then
            bad "codestyle-cpp.py reported violations."
        fi
    else
        warn "codestyle-cpp.py not found at ${CODESTYLE_DIR} -- skipping C++ lint."
    fi

    # --- 4. codestyle-sql ---------------------------------------------------------------------
    if [[ -f "${CODESTYLE_DIR}/codestyle-sql.py" ]]; then
        note "codestyle-sql: linting pending SQL..."
        if ! ( cd "${REPO_ROOT}" && python3 "${CODESTYLE_DIR}/codestyle-sql.py" ); then
            bad "codestyle-sql.py reported violations."
        fi
    else
        warn "codestyle-sql.py not found at ${CODESTYLE_DIR} -- skipping SQL lint."
    fi

    # --- 5. standalone fast core tests --------------------------------------------------------
    note "standalone tests: building + running the pure-core GoogleTests..."
    BUILD_DIR="$(mktemp -d)"
    trap 'rm -rf "${BUILD_DIR}"' EXIT
    if cmake -S "${MODULE_ROOT}/tests/standalone" -B "${BUILD_DIR}" >/dev/null 2>&1 \
        && cmake --build "${BUILD_DIR}" -j"$(nproc 2>/dev/null || echo 2)" >/dev/null 2>&1; then
        if ! "${BUILD_DIR}/branding_core_tests"; then
            bad "standalone core tests failed."
        fi
    else
        bad "standalone core test build failed (see: cmake -S tests/standalone -B <dir>)."
    fi
fi

if [[ "${fail}" -ne 0 ]]; then
    printf '\033[1;31m[pre-commit] commit blocked -- fix the issues above or use --no-verify to bypass.\033[0m\n'
    exit 1
fi

note "all gates passed."
exit 0
