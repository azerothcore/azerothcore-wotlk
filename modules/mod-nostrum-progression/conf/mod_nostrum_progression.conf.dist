################################################################################
# NostrumWoW Progression Module Configuration
#
# Controls server content availability via a two-axis Era + Phase system.
# Change Era/Phase and run `.reload config` to advance the server — no restart.
#
# Unlock rule:
#   required era  < current era  → unlocked
#   required era  > current era  → locked
#   required era == current era  → unlocked if current phase >= required phase
#
# Era values:
#   1 = Azeroth Era   (phases 1-8,  caps: P1=19 P2=29 P3=39 P4=49 P5=59 P6+=60)
#   2 = Outland Era   (phases 1-5,  cap 70)
#   3 = Northrend Era (phases 1-5,  cap 80)
#
# Azeroth Era phases:
#   Phase 1: The Road to 19
#   Phase 2: The Road to 29  (SM Graveyard opens)
#   Phase 3: The Road to 39  (SM Library, Armory & Cathedral open)
#   Phase 4: The Road to 49
#   Phase 5: The Road to 59  (BRD, UBRS, Dire Maul, Stratholme, Scholomance)
#   Phase 6: Molten Core
#   Phase 7: Blackwing Lair & Zul'Gurub
#   Phase 8: Ahn'Qiraj
#
# Outland Era phases:
#   Phase 1: The Road to 69
#   Phase 2: Karazhan, Gruul & Magtheridon
#   Phase 3: Serpentshrine Cavern & Tempest Keep
#   Phase 4: Mount Hyjal & Black Temple
#   Phase 5: Sunwell Plateau
#
# Northrend Era phases:
#   Phase 1: The Road to 79
#   Phase 2: Naxxramas, Obsidian Sanctum & Eye of Eternity
#   Phase 3: Ulduar
#   Phase 4: Trial of the Crusader & Onyxia
#   Phase 5: Icecrown Citadel & Ruby Sanctum
################################################################################

[worldserver]

# Enable or disable the progression module.
# Default: 1
Nostrum.Progression.Enable = 1

################################################################################
# Active Era and Phase
################################################################################

# Current server era. 1=Azeroth  2=Outland  3=Northrend
# Default: 1
Nostrum.Progression.Era = 1

# Current phase within the active era.
# Default: 1
Nostrum.Progression.Phase = 1

################################################################################
# Other options
################################################################################

# Allow GMs (security level >= 2) to bypass the level cap and all content locks.
# Default: 1
Nostrum.Progression.GmBypass = 1

# Send a login message showing the current era, phase, and level cap.
# Default: 1
Nostrum.Progression.LoginAnnouncement = 1

################################################################################
# Progression Content Locks
################################################################################

# Lock dungeon and raid maps by progression era/phase.
# Also gates individual instance wing portals where multiple wings share a map ID
# (e.g. Scarlet Monastery: Graveyard unlocks at Phase 2, Library/Armory/Cathedral at Phase 3).
# Requires the corresponding areatrigger_scripts SQL to be applied (nostrum_progression_areatrigger_scripts.sql).
# Default: 1
Nostrum.Progression.LockInstances = 1

# Lock continent maps (Outland, Northrend, DK zone) by progression era.
# This is the safety net for portals, boats, zeppelins, summons, and hearthstone.
# Default: 1
Nostrum.Progression.LockMaps = 1

# Lock battleground queues by progression era/phase.
# Default: 1
Nostrum.Progression.LockBattlegrounds = 1

# Lock Dungeon Finder (LFG) queues by progression era/phase.
# Default: 1
Nostrum.Progression.LockLFG = 1

# Despawn world bosses (Azuregos, Lord Kazzak, Dragons of Nightmare, etc.)
# when they spawn before their required progression era/phase.
# Default: 1
Nostrum.Progression.LockWorldBosses = 1

# Block purchase of locked badge/emblem currency items from vendors.
# Default: 1
Nostrum.Progression.LockVendors = 1

# If a player logs in inside a locked instance or continent map, teleport them
# to their homebind.
# Default: 1
Nostrum.Progression.TeleportOutOfLockedMapsOnLogin = 1

# Debug logging for progression lock checks.
# Default: 0
Nostrum.Progression.Debug = 0
