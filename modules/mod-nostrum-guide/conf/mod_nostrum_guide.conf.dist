################################################################################
# Nostrum Guide Module
#
# Server onboarding hub NPCs in every starting zone.
# Phase and rate info is read from shared config keys:
#
#   Nostrum.ActivePhase              (shared: mod-nostrum-progression, mod-nostrum-rates)
#   NostrumRates.XP.*                (owned by mod-nostrum-rates)
#   NostrumRates.Profession.*        (owned by mod-nostrum-rates)
#   NostrumRates.Loot.Creature       (owned by mod-nostrum-rates)
#   NostrumRates.Money.Creature      (owned by mod-nostrum-rates)
#   NostrumRates.Reputation.*        (owned by mod-nostrum-rates)
#
# The guide derives phase name and level cap from the bracket table
# (matching mod-nostrum-rates) driven by Nostrum.ActivePhase.
# Do NOT duplicate those keys here.
################################################################################

[worldserver]

# Master switch. Set to 0 to disable gossip without removing spawns.
# Default: 1
NostrumGuide.Enable = 1

################################################################################
# NPC Settings
################################################################################

# Entry IDs for the guide NPC templates (must match SQL creature_template).
# Default: 900001 (Alliance), 900002 (Horde)
NostrumGuide.AllianceNpcEntry = 900001
NostrumGuide.HordeNpcEntry = 900002

################################################################################
# Permanent Visual Cue
################################################################################

# Spawn a gameobject at each guide NPC location so new players notice it.
# Default: 1
NostrumGuide.VisualCue.Enable = 1

# Gameobject entry used as the visual cue.
# Default: 149410
NostrumGuide.VisualCue.GameObjectEntry = 149410

################################################################################
# Links
################################################################################

NostrumGuide.WebsiteUrl = https://nostrumwow.com
NostrumGuide.DiscordUrl = https://discord.gg/ebvrN5kqTJ

################################################################################
# Rates Description
#
# Phase, level cap, and numeric rates are auto-read from Nostrum.ActivePhase
# and NostrumRates.* keys. This text is appended after the rate summary
# in the NPC "Features, phase & rates" menu for additional context.
################################################################################

NostrumGuide.RatesText = "XP is phase-driven. Current bracket: blizzlike. Previous brackets: catch-up. Gold is mailed at every 10 levels."

################################################################################
# World Chat
#
# The guide reads WorldChat.ChannelName (owned by mod-world-chat) to join
# players server-side. Only override here if you want a different channel.
################################################################################

# WorldChat.ChannelName = world

################################################################################
# Debug
################################################################################

# Verbose per-gossip-open debug logging. Leave disabled in production.
# Default: 0
NostrumGuide.Debug = 0